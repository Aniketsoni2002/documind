# Copy to `.env` and adjust as needed. All values are optional — the defaults
# target a fully local stack and require no API keys.

# --- LLM (Ollama) ---
DOCUMIND_OLLAMA_BASE_URL=http://localhost:11434
DOCUMIND_LLM_MODEL=llama3.2
DOCUMIND_LLM_TEMPERATURE=0.1

# --- Embeddings (HuggingFace, runs locally) ---
DOCUMIND_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval / chunking ---
DOCUMIND_TOP_K=4
DOCUMIND_CHUNK_SIZE=1000
DOCUMIND_CHUNK_OVERLAP=150
