# Copy this into Streamlit Community Cloud → your app → Settings → Secrets,
# or into a local `.streamlit/secrets.toml` (which is git-ignored).
#
# For the hosted deploy, DocuMind uses the Groq API as its LLM.

DOCUMIND_LLM_PROVIDER = "groq"
DOCUMIND_GROQ_API_KEY = "gsk_your_groq_api_key_here"
DOCUMIND_GROQ_MODEL = "llama-3.1-8b-instant"
